# =============================================================================
# .env.example — Nikola AI
#
# Copy this file to `.env` and adjust values as needed for local development.
# `.env` itself is gitignored and must NEVER be committed.
#
# As of Sprint 2, configuration is resolved in this priority order
# (highest wins): real environment variables > this .env file >
# config/default.yaml > field defaults. See
# src/nikola/infrastructure/config/settings.py for the full schema.
#
# Nested settings use a double-underscore delimiter: NIKOLA_<SECTION>__<FIELD>.
# Everything below is commented out and shown at its default value — this
# file working with everything commented out (i.e. falling through entirely
# to config/default.yaml and field defaults) is itself part of what Sprint 2
# verifies.
# =============================================================================

# --- App ----------------------------------------------------------------------
# NIKOLA_APP__NAME="Nikola AI"
# NIKOLA_APP__ENVIRONMENT=development   # development | testing | staging | production
# NIKOLA_APP__DEBUG=false

# --- Logging --------------------------------------------------------------------
# NIKOLA_LOGGING__LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR | CRITICAL
# NIKOLA_LOGGING__JSON_FORMAT=true
# NIKOLA_LOGGING__CONSOLE_ENABLED=true
# NIKOLA_LOGGING__FILE_PATH=logs/nikola.log   # unset (default) = no file logging

# --- Advanced: override which YAML file is read as the base config layer -------
# NIKOLA_CONFIG_FILE=config/default.yaml

# --- Reserved for future sprints (NOT used yet) ---------------------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

