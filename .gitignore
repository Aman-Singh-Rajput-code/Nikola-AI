# =============================================================================
# .gitignore — Nikola AI
# =============================================================================

# --- Python bytecode / build artifacts -------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.eggs/
*.egg

# --- Virtual environments ---------------------------------------------------
.venv/
venv/
env/
ENV/

# --- Distribution / packaging -----------------------------------------------
wheels/
pip-wheel-metadata/

# --- Testing & coverage -------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# --- Type checking caches -----------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# --- pre-commit ---------------------------------------------------------------
.pre-commit-cache/

# --- Environment / secrets -----------------------------------------------------
.env
.env.*
!.env.example

# --- Local data the app will generate in later sprints -------------------------
# (No real data exists yet in Sprint 1; these are reserved paths so future
# sprints don't accidentally commit user data, conversation DBs, or audit logs.)
*.db
*.sqlite3
.nikola/
logs/

# --- Editors / IDEs -------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS noise --------------------------------------------------------------------
.DS_Store
Thumbs.db
